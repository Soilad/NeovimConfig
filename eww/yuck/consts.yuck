(defpoll activewindow :interval "2s" `hyprctl activewindow -j`)
; (deflisten notifs :initial "" `python ~/.config/eww/scripts/notifs.py`)
(defpoll activeworkspace :interval "2s" `hyprctl activeworkspace -j`)
(defpoll weather :interval "3h" `scripts/weather.sh`)
(defpoll notes :interval "10s" `cat ~/Documents/Obsidian-Vault/todo.md`)
(defpoll playerctl :interval "2s" `playerctl metadata -f '{ "artist": "{{ artist }}", "title": "{{ title }}", "position": {{ position }}, "length": {{ mpris:length }}, "artUrl": "{{ mpris:artUrl }}", "status": "{{ status }}" }' 2>/dev/null | jq -s 'if length == 0 then {"status": "Stopped"} else .[0] end'`)

(defvar speaker-volume 100)
(defvar mic-volume 100)


(defvar wifilist `[]`)
(defvar user "soi")
(defvar pc "wowbigredsquarething")
(defvar glow-value 0.5)
(defvar notif true)

(deflisten cava :interval "0s" `bash ~/.config/eww/scripts/cava.sh 70`)

(defvar height 64)
(defvar power-spacing 10)
(defvar side-spacing 10)
(defvar search-spacing 20)
(defvar cap 48)
(defvar circular-thickness 2)
(defvar player-button-spacing 15)
(defvar player-text-spacing 5)
(defvar weather-spacing 100)

